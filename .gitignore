# 루트 공통 .gitignore — 모든 하위 샘플 앱 프로젝트가 이 패턴을 공유합니다.
# (gitignore 패턴은 하위 디렉터리에도 재귀 적용됩니다.)

# Gradle
.gradle/
build/

# Local configuration (SDK 경로, 서명 키 등) — 절대 커밋하지 않음
local.properties

# Android Studio / IntelliJ
.idea/
*.iml
.DS_Store
captures/
.externalNativeBuild/
.cxx/

# Logs & 빌드 산출물
*.log
*.apk
*.aab
*.ap_
*.dex
*.class

# Keystore
*.jks
*.keystore

# Kotlin
.kotlin/

.gradle
/local.properties
/.idea/caches
/.idea/libraries
/.idea/modules.xml
/.idea/workspace.xml
/.idea/navEditor.xml
/.idea/assetWizardSettings.xml
/build
/captures
.externalNativeBuild
.cxx
gradle/gradle-daemon-jvm.properties
